SP_ENV=development
SP_APP_NAME=SicherPlan API
SP_APP_VERSION=0.1.0
SP_API_HOST=0.0.0.0
SP_API_PORT=8000
SP_API_BASE_URL=http://localhost:8000
SP_ALLOWED_ORIGINS=http://localhost:5173

SP_DB_HOST=localhost
SP_DB_PORT=5432
SP_DB_NAME=sicherplan
SP_DB_USER=sicherplan
SP_DB_PASSWORD=change-me
SP_DB_CONNECT_TIMEOUT_SECONDS=5

SP_DB_ECHO=false
SP_DATABASE_URL=
SP_ALEMBIC_DATABASE_URL=postgresql+psycopg://sicherplan:change-me@localhost:5432/sicherplan

SP_OBJECT_STORAGE_ENDPOINT=http://localhost:9000
SP_OBJECT_STORAGE_BACKEND=filesystem
SP_OBJECT_STORAGE_REGION=eu-central-1
SP_OBJECT_STORAGE_BUCKET=sicherplan-dev
SP_OBJECT_STORAGE_ACCESS_KEY=minioadmin
SP_OBJECT_STORAGE_SECRET_KEY=change-me
SP_OBJECT_STORAGE_USE_SSL=false
SP_OBJECT_STORAGE_FILESYSTEM_ROOT=/tmp/sicherplan-object-storage

SP_AUTH_SESSION_SECRET=change-me
SP_AUTH_ACCESS_TOKEN_TTL_MINUTES=15
SP_AUTH_REFRESH_TOKEN_TTL_MINUTES=10080
SP_AUTH_PASSWORD_RESET_TOKEN_TTL_MINUTES=30
SP_AUTH_LOGIN_MAX_ATTEMPTS=5
SP_AUTH_LOCKOUT_MINUTES=15
SP_AUTH_EXTERNAL_IDP_ENABLED=false
SP_AUTH_EXTERNAL_IDP_DISCOVERY_URL=
SP_AUTH_EXTERNAL_IDP_CLIENT_ID=
SP_AUTH_EXTERNAL_IDP_CLIENT_SECRET=

SP_MESSAGE_EMAIL_ENABLED=false
SP_MESSAGE_SMS_ENABLED=false
SP_MESSAGE_PUSH_ENABLED=false
SP_MESSAGE_EMAIL_FROM=no-reply@example.invalid

SP_INTEGRATION_OUTBOX_ENABLED=true
SP_INTEGRATION_SECRET_KEY=change-me
SP_INTEGRATION_OUTBOX_BATCH_SIZE=25
SP_INTEGRATION_OUTBOX_RETRY_DELAY_SECONDS=60
SP_INTEGRATION_OUTBOX_MAX_ATTEMPTS=3
SP_INTEGRATION_PAYROLL_EXPORT_ENABLED=false
SP_INTEGRATION_MAPS_ENABLED=false

SP_LOG_LEVEL=INFO
