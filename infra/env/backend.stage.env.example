SP_ENV=staging
SP_APP_NAME=SicherPlan API
SP_APP_VERSION=0.1.0
SP_API_HOST=0.0.0.0
SP_API_PORT=8000
SP_API_BASE_URL=https://stage.example.com/api
SP_ALLOWED_ORIGINS=https://stage.example.com
SP_LOG_LEVEL=INFO

SP_DB_HOST=postgres
SP_DB_PORT=5432
SP_DB_NAME=sicherplan
SP_DB_USER=sicherplan
SP_DB_PASSWORD=replace-with-the-same-password-as-stage.env
SP_DB_ECHO=false
SP_DB_CONNECT_TIMEOUT_SECONDS=5
SP_ALEMBIC_DATABASE_URL=postgresql+psycopg://sicherplan:replace-with-the-same-password-as-stage.env@postgres:5432/sicherplan
SP_DB_RLS_ENABLED=false
SP_DB_RLS_DEFAULT_MODE=off

SP_OBJECT_STORAGE_ENDPOINT=file:///var/lib/sicherplan/object-storage
SP_OBJECT_STORAGE_BACKEND=filesystem
SP_OBJECT_STORAGE_REGION=eu-central-1
SP_OBJECT_STORAGE_BUCKET=sicherplan-stage
SP_OBJECT_STORAGE_ACCESS_KEY=
SP_OBJECT_STORAGE_SECRET_KEY=
SP_OBJECT_STORAGE_USE_SSL=false
SP_OBJECT_STORAGE_FILESYSTEM_ROOT=/var/lib/sicherplan/object-storage

SP_AUTH_SESSION_SECRET=replace-with-a-long-random-secret
SP_AUTH_ACCESS_TOKEN_TTL_MINUTES=15
SP_AUTH_REFRESH_TOKEN_TTL_MINUTES=10080
SP_AUTH_PASSWORD_RESET_TOKEN_TTL_MINUTES=30
SP_AUTH_LOGIN_MAX_ATTEMPTS=5
SP_AUTH_LOCKOUT_MINUTES=15
SP_AUTH_EXTERNAL_IDP_ENABLED=false
SP_AUTH_EXTERNAL_IDP_DISCOVERY_URL=
SP_AUTH_EXTERNAL_IDP_CLIENT_ID=
SP_AUTH_EXTERNAL_IDP_CLIENT_SECRET=

SP_MESSAGE_EMAIL_ENABLED=false
SP_MESSAGE_SMS_ENABLED=false
SP_MESSAGE_PUSH_ENABLED=false
SP_MESSAGE_EMAIL_FROM=no-reply@stage.example.com

SP_INTEGRATION_OUTBOX_ENABLED=true
SP_INTEGRATION_SECRET_KEY=replace-with-a-separate-long-random-secret
SP_INTEGRATION_OUTBOX_BATCH_SIZE=25
SP_INTEGRATION_OUTBOX_RETRY_DELAY_SECONDS=60
SP_INTEGRATION_OUTBOX_MAX_ATTEMPTS=3
SP_INTEGRATION_PAYROLL_EXPORT_ENABLED=false
SP_INTEGRATION_MAPS_ENABLED=false

SP_SECURITY_RATE_LIMIT_ENABLED=true
SP_SECURITY_RATE_LIMIT_WINDOW_SECONDS=300
SP_SECURITY_RATE_LIMIT_AUTH_REFRESH_MAX=30
SP_SECURITY_RATE_LIMIT_DOCUMENT_DOWNLOAD_MAX=60
SP_SECURITY_RATE_LIMIT_REPORT_EXPORT_MAX=20
